        "68432a894ad44ae82e8f6f62": {
          "type": "carousel",
          "data": {
            "name": "Card",
            "cards": [
              {
                "id": "jf1cd3vwm",
                "title": "Nakaz jazdy w prawo przed znakiem",
                "description": [
                  {
                    "children": [
                      {
                        "text": "Zobowiązuje kierującego do jazdy w prawo przed znakiem; znak ten może być umieszczony na przedłużeniu osi drogi (jezdni) lub na samej jezdni.\r\nZnak obowiązuje na najbliższym skrzyżowaniu lub w miejscu, gdzie występuje możliwość zmiany kierunku jazdy."
                      }
                    ]
                  }
                ],
                "imageUrl": "https://www.prawo-jazdy-360.pl/image/znaki-drogowe/C-1-nakaz-jazdy-w-prawo-przed-znakiem.webp",
