  "responseMessages": [
    {
      "id": "684324aa9f12cdf556ae567d",
      "discriminatorID": "684324aa9f12cdf556ae567c",
      "text": [
        {
          "text": [
            "Podaj maila, na którego wysłany zostanie wynik."
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "684324dd01606e704f0db9b8",
      "discriminatorID": "684324dd01606e704f0db9b7",
      "text": [
        {
          "text": [
            "Wybierz następną opcję"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "6843284b01606e704f0dbbcf",
      "discriminatorID": "6843284b01606e704f0dbbce",
      "text": [
        {
          "text": [
            "Zaraz zostaną dla Ciebie wyświetlone wybrane przez twórcę, jego zdaniem, najważniejsze znaki zakazu."
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "684328f401606e704f0dbc10",
      "discriminatorID": "684328f401606e704f0dbc0f",
      "text": [
        {
          "text": [
            "Zaraz zostaną dla Ciebie wyświetlone wybrane przez twórcę, jego zdaniem, najważniejsze znaki Informacyjne"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "68432b7001606e704f0dbdb3",
      "discriminatorID": "68432b7001606e704f0dbdb2",
      "text": [
        {
          "text": [
            "Dziękuję za dzisiaj ",
            {
              "entityID": "6842e15e5242e589b0bffe69"
            },
            " , do usłyszenia!"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "68432f3f9f12cdf556ae56a7",
      "discriminatorID": "68432f3f9f12cdf556ae56a6",
      "text": [
        {
          "text": [
            "Masz pytanie odnośnie znaków zakazu? Śmiało, zadaj je!"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "68432ef101606e704f0dbfa4",
      "discriminatorID": "68432ef101606e704f0dbfa3",
      "text": [
        {
          "text": [
            "Masz pytanie odnośnie znaków ostrzegawczych? Śmiało, zadaj je!"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-06-09T15:07:50.000Z"
    },
    {
      "id": "68432f4d9f12cdf556ae56aa",
      "discriminatorID": "68432f4d9f12cdf556ae56a9",
      "text": [
        {
          "text": [
            "Masz pytanie odnośnie znaków informacyjnych? Śmiało, zadaj je!"
          ]
        }
      ],
      "condition": null,
