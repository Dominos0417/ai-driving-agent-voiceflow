    {
      "id": "6845f71901606e704f0ef228",
      "promptID": "6845f7179f12cdf556ae6984",
      "pairID": null,
      "type": "role",
      "data": {
        "role": "user",
        "content": [
          {
            "text": [
              "Jesteś AI które ma odpowiedzieć na wątpliwości co do pytania w egzaminie do prawa jazdy. Uargumentuj swoją wypowiedź oraz podaj przykład."
            ]
          },
          {
            "text": [
              {
                "text": [
                  ""
                ]
              }
            ]
          },
          {
            "text": [
              "Odpowiedź dotyczy polskich przepisów drogowych oraz znaków"
            ]
          },
          {
            "text": [
              {
                "text": [
                  ""
                ]
              }
            ]
          },
          {
            "text": [
              "Pytanie którego dotyczą wątpliwości: ",
              {
                "variableID": "6845e52801606e704f0ee978"
              },
              " "
            ]
          },
          {
            "text": [
              "Odpowiedź prawidłowa: ",
              {
                "variableID": "6845e53c01606e704f0ee97f"
              },
              " "
            ]
          },
          {
            "text": [
              "Odpowiedź  udzielona przez użytkownika: ",
              {
                "variableID": "6845f63a01606e704f0ef161"
              },
              " "
            ]
          },
          {
            "text": [
              "Pytanie które zadał użytkownik ",
              {
                "variableID": "6845d4fd01606e704f0ee04a"
              },
              " "
            ]
          }
        ]
      },
      "createdAt": "2024-11-06T18:25:22.000Z"
    },
    {
      "id": "6845d3e49f12cdf556ae67fd",
